# Auto-Deploy Bot Configuration

# ============================================
# Vercel Configuration
# ============================================
# Get from: https://vercel.com/account/tokens
VERCEL_TOKEN=your_vercel_token_here

# ============================================
# Namecheap Configuration (Recommended)
# ============================================
# Get from: https://www.namecheap.com/support/api/
NAMECHEAP_API_KEY=your_namecheap_api_key
NAMECHEAP_API_USER=your_namecheap_username

# ============================================
# Porkbun Configuration
# ============================================
# Get from: https://porkbun.com/account/api
PORKBUN_API_KEY=your_porkbun_api_key
PORKBUN_SECRET_API_KEY=your_porkbun_secret_key

# ============================================
# GoDaddy Configuration
# ============================================
# Get from: https://developer.godaddy.com
GODADDY_API_KEY=your_godaddy_api_key
GODADDY_API_SECRET=your_godaddy_api_secret

# ============================================
# AWS Configuration (Route53)
# ============================================
# Get from: https://aws.amazon.com/iam/
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# ============================================
# Optional Settings
# ============================================
# Default registrar for purchases
DEFAULT_REGISTRAR=namecheap

# Default preferred TLDs (space-separated)
PREFERRED_TLDS=.com .io .co

# Default max domain price
MAX_DOMAIN_PRICE=50.0

# Auto-renewal enabled by default
AUTO_RENEW=true

# Privacy protection enabled by default
PRIVACY_PROTECTION=true

# Vercel deployment timeout (seconds)
DEPLOYMENT_TIMEOUT=300

# DNS propagation check timeout (seconds)
DNS_TIMEOUT=600
