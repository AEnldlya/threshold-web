# Instagram Reels Skill - Configuration Template
# Copy this file to .env and customize for your environment

# ============================================================================
# Instagram Credentials (Optional)
# Only needed if you want to access private accounts
# ============================================================================
INSTAGRAM_USERNAME=your_instagram_username
INSTAGRAM_PASSWORD=your_instagram_password

# ============================================================================
# Cache Configuration
# ============================================================================
# Where to store downloaded reels and metadata
CACHE_DIR=~/.openclaw/workspace/.cache/instagram-reels

# Temporary directory for processing
TEMP_DIR=/tmp/instagram-reels

# ============================================================================
# Download Configuration
# ============================================================================
# Maximum number of concurrent downloads (3 is safe to avoid rate limiting)
MAX_CONCURRENT_DOWNLOADS=3

# Delay between requests in seconds (Instagram rate limiting)
REQUEST_DELAY_SECONDS=2

# Wait time before retry after rate limit (seconds)
RATE_LIMIT_BACKOFF_SECONDS=60

# ============================================================================
# Browser Configuration
# ============================================================================
# Run browser in headless mode (no UI window)
BROWSER_HEADLESS=true

# Enable Playwright debugging
PLAYWRIGHT_DEBUG=false

# ============================================================================
# Analysis Configuration
# ============================================================================
# Automatically extract design patterns from reels
EXTRACT_ANALYSIS=true

# Include video files in downloads
INCLUDE_VIDEOS=false

# Include thumbnail images in downloads
INCLUDE_IMAGES=true

# ============================================================================
# Output Configuration
# ============================================================================
# Where to save DESIGN_REFERENCES.md
OUTPUT_MARKDOWN_FILE=~/.openclaw/workspace/DESIGN_REFERENCES.md

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# ============================================================================
# Advanced Configuration
# ============================================================================
# Use proxy for requests (optional)
USE_PROXY=false
PROXY_URL=http://proxy.example.com:8080

# Cache expiration time in hours (default: 24)
CACHE_MAX_AGE_HOURS=24

# Enable verbose logging
VERBOSE=false
