# 3D Animations Skill Configuration

# 21st.dev Integration
TWENTYFIRST_DEV_URL=https://21st.dev
TWENTYFIRST_DEV_API_KEY=your_api_key_here

# Performance Targets
TARGET_FPS=60
TARGET_LIGHTHOUSE=95
MOBILE_QUALITY_SCALE=0.75

# Deployment Settings
AUTO_DEPLOY=false
VERCEL_TOKEN=your_vercel_token_here
GITHUB_TOKEN=your_github_token_here

# Optimization Settings
ENABLE_LOD=true
ENABLE_TEXTURE_COMPRESSION=true
MAX_DRAW_CALLS=100
MAX_PARTICLE_COUNT=2000

# Mobile Settings
MOBILE_TARGET_FPS=30
MOBILE_QUALITY_SCALE=0.75
ENABLE_MOBILE_OPTIMIZATION=true

# Logging
LOG_LEVEL=INFO
DEBUG=false

# Cache Settings
CACHE_TTL_HOURS=24
ENABLE_LOCAL_CACHE=true
CACHE_DIR=~/.openclaw/workspace/skills/3d-animations/.cache
